<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Scoria"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="syn7xx"
    UpgradeCode="A9B1C3F4-6D18-4F85-9B51-3E2A31B4E2D9">
    <Package InstallerVersion="500" Compressed="yes" InstallScope="perMachine" Platform="x64" />
    <Icon Id="ScoriaProductIcon" SourceFile="$(var.SourceDir)\scoria.exe" />
    <Property Id="ARPPRODUCTICON" Value="ScoriaProductIcon" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <Property Id="CREATE_DESKTOP_SHORTCUT" Value="1" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Scoria now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <CustomAction
      Id="LaunchScoriaAfterInstall"
      FileKey="ScoriaExeFile"
      ExeCommand=""
      Return="asyncNoWait"
      Impersonate="yes" />
    <Binary Id="CreateDesktopShortcutScript" SourceFile="packaging/windows/create_desktop_shortcut.vbs" />
    <CustomAction
      Id="CreateDesktopShortcutCA"
      BinaryKey="CreateDesktopShortcutScript"
      VBScriptCall="CreateDesktopShortcut"
      Execute="immediate"
      Impersonate="yes"
      Return="ignore" />

    <UIRef Id="ScoriaInstallUI" />

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Scoria is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="Scoria" />
      </Directory>
      <!-- Standard shell folder ids (no Name): required so Light resolves DirectoryRef. -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuScoriaFolder" Name="Scoria" />
      </Directory>
      <Directory Id="DesktopFolder" />
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="ScoriaExeComponent" Guid="8A0F0F64-9D54-4BE7-A4F7-4A090B1EAB8A" Win64="yes">
        <File Id="ScoriaExeFile" Source="$(var.SourceDir)\scoria.exe" KeyPath="yes" />
        <Environment
          Id="ScoriaPath"
          Name="PATH"
          Action="set"
          Part="last"
          System="yes"
          Value="[INSTALLFOLDER]" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ProgramMenuScoriaFolder">
      <Component Id="StartMenuShortcutComponent" Guid="BA094A84-14DC-4A20-8785-F3374B5B8F62" Win64="yes">
        <Shortcut
          Id="StartMenuShortcut"
          Name="Scoria"
          Description="Save clipboard to Obsidian vault"
          Target="[#ScoriaExeFile]"
          WorkingDirectory="INSTALLFOLDER"
          Icon="ScoriaProductIcon"
          Advertise="no">
          <ShortcutProperty Key="System.AppUserModel.ID" Value="syn7xx.Scoria" />
        </Shortcut>
        <RemoveFolder Id="ProgramMenuScoriaFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\syn7xx\Scoria"
          Name="StartMenuShortcut"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcutRemoveComponent" Guid="C3D4E5F6-A7B8-9012-CDEF-123456789ABC" Win64="yes">
        <RemoveFile Id="RemoveDesktopScoriaLnk" Name="Scoria.lnk" On="uninstall" Directory="DesktopFolder" />
        <RegistryValue
          Root="HKCU"
          Key="Software\syn7xx\Scoria"
          Name="DesktopShortcutRemove"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="MainFeature" Title="Scoria" Level="1">
      <ComponentRef Id="ScoriaExeComponent" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="DesktopShortcutRemoveComponent" />
    </Feature>
  </Product>

  <Fragment>
    <UI Id="ScoriaInstallUI">
      <UIRef Id="WixUI_InstallDir" />

      <InstallUISequence>
        <Show Dialog="ScoriaExitDlg" OnExit="success" Overridable="no" />
      </InstallUISequence>
      <AdminUISequence>
        <Show Dialog="ScoriaExitDlg" OnExit="success" Overridable="no" />
      </AdminUISequence>

      <Dialog Id="ScoriaExitDlg" Width="370" Height="270" Title="!(loc.ExitDialog_Title)">
        <Control Id="Finish" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Cancel="yes" Text="!(loc.WixUIFinish)">
          <Publish Event="DoAction" Value="LaunchScoriaAfterInstall" Order="1">
            WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed
          </Publish>
          <Publish Event="DoAction" Value="CreateDesktopShortcutCA" Order="2">CREATE_DESKTOP_SHORTCUT = 1 AND NOT Installed</Publish>
          <Publish Event="EndDialog" Value="Return" Order="999">1</Publish>
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Disabled="yes" Text="!(loc.WixUICancel)" />
        <Control Id="Bitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="234" TabSkip="no" Text="!(loc.ExitDialogBitmap)" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="!(loc.WixUIBack)" />
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="370" Height="0" />
        <Control
          Id="Description"
          Type="Text"
          X="135"
          Y="70"
          Width="220"
          Height="40"
          Transparent="yes"
          NoPrefix="yes"
          Text="!(loc.ExitDialogDescription)" />
        <Control Id="Title" Type="Text" X="135" Y="20" Width="220" Height="60" Transparent="yes" NoPrefix="yes" Text="!(loc.ExitDialogTitle)" />
        <Control Id="OptionalText" Type="Text" X="135" Y="110" Width="220" Height="50" Transparent="yes" NoPrefix="yes" Hidden="yes" Text="[WIXUI_EXITDIALOGOPTIONALTEXT]">
          <Condition Action="show">WIXUI_EXITDIALOGOPTIONALTEXT AND NOT Installed</Condition>
        </Control>
        <Control
          Id="OptionalCheckBox"
          Type="CheckBox"
          X="135"
          Y="165"
          Width="220"
          Height="22"
          Hidden="yes"
          Property="WIXUI_EXITDIALOGOPTIONALCHECKBOX"
          CheckBoxValue="1"
          Text="[WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT]">
          <Condition Action="show">WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT AND NOT Installed</Condition>
        </Control>
        <Control
          Id="DesktopShortcutCheck"
          Type="CheckBox"
          X="135"
          Y="192"
          Width="220"
          Height="22"
          Hidden="yes"
          Property="CREATE_DESKTOP_SHORTCUT"
          CheckBoxValue="1"
          Text="Create a desktop shortcut">
          <Condition Action="show">NOT Installed</Condition>
        </Control>
      </Dialog>

      <Publish Dialog="WelcomeDlg" Control="Next" Event="NewDialog" Value="InstallDirDlg" Order="2">1</Publish>
      <Publish Dialog="InstallDirDlg" Control="Back" Event="NewDialog" Value="WelcomeDlg" Order="2">1</Publish>
    </UI>
  </Fragment>
</Wix>
